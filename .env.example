# MiniMax M3 (Anthropic 兼容协议)
UNI_RAG_LLM_BASE_URL=https://api.minimaxi.com/anthropic
UNI_RAG_LLM_API_KEY=your-key-here
UNI_RAG_LLM_MODEL=MiniMax-M3

# 阶跃星辰 Step Plan (Anthropic 兼容)
UNI_RAG_STEPFUN_API_KEY=your-key-here
UNI_RAG_STEPFUN_MODEL=step-3.7-flash

# 本地 CLI Proxy (OpenAI 兼容)
UNI_RAG_CLI_PROXY_API_KEY=
UNI_RAG_CLI_PROXY_MODEL=gpt-4o

# 数据目录
UNI_RAG_DATA_DIR_PATH=./data
UNI_RAG_MAX_SESSION_MESSAGES=20

# LlamaCloud API Key
UNI_RAG_LLAMA_CLOUD_API_KEY=your-key-here
